{
  "name": "r2-manager",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "build:cf": "NITRO_PRESET=cloudflare_module nuxt build",
    "dev": "nuxt dev",
    "dev:cf": "npm run build:cf && wrangler dev .output/server/index.mjs",
    "deploy:cf": "npm run build:cf && wrangler deploy .output/server/index.mjs",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "typecheck": "nuxt typecheck",
    "preview:cf": "pnpm build && npx wrangler pages dev dist --r2 R2_BUCKET=base"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.98",
    "@iconify-json/simple-icons": "^1.2.74",
    "@nuxt/ui": "^4.5.1",
    "nuxt": "^4.4.2",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "eslint": "^10.0.3",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.5",
    "wrangler": "^4.38.0"
  },
  "packageManager": "pnpm@10.32.1"
}
